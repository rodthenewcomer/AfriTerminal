# Public runtime configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Server-only Supabase administration (webhooks and account deletion only)
SUPABASE_SECRET_KEY=sb_secret_replace_me

# Server operations and privacy-preserving request hashing (32+ random characters each)
CRON_SECRET=replace_with_a_long_random_cron_secret
OPS_SECRET=replace_with_a_long_random_operations_secret
RATE_LIMIT_HASH_SECRET=replace_with_a_long_random_rate_limit_secret
ANALYTICS_HASH_SECRET=replace_with_a_long_random_analytics_secret

# Transactional alert delivery
EXPO_ACCESS_TOKEN=replace_with_expo_enhanced_security_token
RESEND_API_KEY=re_replace_me
RESEND_FROM=WARIBA <notifications@wariba.app>
RESEND_WEBHOOK_SECRET=whsec_replace_me

# Stripe web billing
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_PRO_MONTHLY=price_replace_me
NEXT_PUBLIC_PRO_PRICE_LABEL=4 900 FCFA / mois

# Native App Store / Google Play billing via RevenueCat
REVENUECAT_SECRET_API_KEY=sk_replace_me
REVENUECAT_ENTITLEMENT_ID=pro
REVENUECAT_WEBHOOK_AUTH=Bearer replace_with_a_long_random_value

# Expo embeds only EXPO_PUBLIC_* values in the client bundle
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SITE_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=appl_replace_me
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=goog_replace_me
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
EXPO_PUBLIC_EAS_PROJECT_ID=replace_with_eas_project_uuid
EXPO_PUBLIC_ANALYTICS_ENABLED=true
